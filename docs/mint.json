{
  "$schema": "https://mintlify.com/schema.json",
  "name": "Aria",
  "logo": {
    "dark": "/aria-logo.svg",
    "light": "/aria-logo.svg"
  },
  "favicon": "/aria-logo.svg",
  "colors": {
    "primary": "#E8E8E8",
    "light": "#F5F5F5",
    "dark": "#0A0A0A",
    "anchors": {
      "from": "#A3A3A3",
      "to": "#E5E5E5"
    }
  },
  "theme": "mint",
  "modeToggle": {
    "default": "dark",
    "isHidden": true
  },
  "topbarLinks": [
    {
      "name": "App",
      "url": "/"
    }
  ],
  "navigation": [
    {
      "group": "Start here",
      "pages": ["introduction", "product-positioning", "quickstart"]
    },
    {
      "group": "Architecture",
      "pages": [
        "architecture/overview",
        "architecture/system-map",
        "architecture/data-flow",
        "architecture/trust-boundary"
      ]
    },
    {
      "group": "Capabilities",
      "pages": [
        "capabilities/chat",
        "capabilities/deep-research",
        "capabilities/web-search",
        "capabilities/models",
        "capabilities/export-share"
      ]
    },
    {
      "group": "API & Contracts",
      "pages": ["api/chat", "api/contracts"]
    },
    {
      "group": "Platform roadmap",
      "pages": [
        "roadmap/bnii-surfaces",
        "roadmap/build-priorities",
        "roadmap/governance"
      ]
    }
  ]
}
